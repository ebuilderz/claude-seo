NODE_ENV=production
PORT=3000
APP_NAME=Claude SEO — Upstream
AUTH_MODE=basic
BASIC_AUTH_USER=seo-team
BASIC_AUTH_PASSWORD=replace-with-a-long-random-password

# Dedicated OpenAI project key. Set a hard spending limit in the OpenAI project.
CODEX_API_KEY=
CODEX_MODEL=gpt-5.6-luna
CODEX_REASONING_EFFORT=medium

AUDIT_TIMEOUT_MS=1800000
AUDIT_MAX_PER_24H=3
AUDIT_MAX_PER_USER_24H=3
AUDIT_MAX_PENDING=1
AUDIT_MAX_COMPLETION_PASSES=2
