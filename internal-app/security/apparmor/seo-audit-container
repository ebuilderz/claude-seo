#include <tunables/global>

# Outer profile for the private SEO audit application. This retains Docker's
# normal procfs and sysfs restrictions while permitting one explicit transition
# to Ubuntu's bwrap-userns-restrict profile. Mount-related syscalls are limited
# separately by the dedicated seccomp profile; the container still runs as a
# non-root user with all Linux capabilities dropped.
profile seo-audit-container flags=(attach_disconnected,mediate_deleted) {
  network,
  deny network alg,
  capability,
  file,
  mount,
  umount,
  pivot_root,
  userns,
  signal,
  ptrace (trace,tracedby,read,readby) peer=seo-audit-container,

  change_profile -> bwrap,

  deny @{PROC}/* w,
  deny @{PROC}/{[^1-9/],[^1-9/][^0-9/],[^1-9s/][^0-9y/][^0-9s/],[^1-9/][^0-9/][^0-9/][^0-9/]*}/** w,
  deny @{PROC}/sys/[^k]** w,
  deny @{PROC}/sys/kernel/{?,??,[^s][^h][^m]**} w,
  deny @{PROC}/sysrq-trigger rwklx,
  deny @{PROC}/kcore rwklx,

  deny /sys/[^f]*/** wklx,
  deny /sys/f[^s]*/** wklx,
  deny /sys/fs/[^c]*/** wklx,
  deny /sys/fs/c[^g]*/** wklx,
  deny /sys/fs/cg[^r]*/** wklx,
  deny /sys/firmware/** rwklx,
  deny /sys/devices/virtual/powercap/** rwklx,
  deny /sys/kernel/security/** rwklx,
}
