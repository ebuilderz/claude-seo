NODE_ENV=production
PORT=3000
APP_NAME=eBuilderz SEO Audit
APP_DESCRIPTION=Internal technical SEO and AI-search quality control.

# Recommended: a Cloudflare Access self-hosted application in front of this service.
AUTH_MODE=cloudflare-access
CF_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-access-application-audience-tag
ALLOWED_EMAIL_DOMAINS=your-company.com
ALLOWED_EMAILS=

# Temporary fallback if Cloudflare Access is not available yet.
# AUTH_MODE=basic
# BASIC_AUTH_USER=seo-team
# BASIC_AUTH_PASSWORD=replace-with-a-long-random-password

# Use a dedicated OpenAI project key with a conservative project spend limit.
CODEX_API_KEY=
CODEX_MODEL=gpt-5.6-sol
AUDIT_TIMEOUT_MS=1800000
